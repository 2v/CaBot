# Copy this to config.ini (in this folder or the repo root) and fill in your keys.
# config.ini is gitignored. The scripts also accept environment variables instead
# (OPENROUTER_API_KEY / OPENAI_API_KEY / HF_TOKEN).
[main]
# --- Embeddings: provide ONE of these (used by 02_build_embeddings.py & 04_search.py).
# OpenRouter (OpenAI-compatible gateway) -- routes to the same text-embedding-3-small:
OPENROUTER_KEY=sk-or-your-openrouter-key
# ...or OpenAI directly:
OPENAI_KEY=sk-your-openai-key
# Optional: force a provider when both keys are present ("openrouter" or "openai").
# Defaults to OpenRouter if its key is present, otherwise OpenAI.
# EMBED_PROVIDER=openrouter

# --- HuggingFace write token, used by 03_upload_huggingface.py to publish the dataset.
HF_WRITE_TOKEN=hf_your-write-token
